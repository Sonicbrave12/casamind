<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Casamind</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            background-color: #111;
            color: white;
            transition: background-color 0.5s;
        }

        h1 {
            margin-top: 40px;
            font-size: 3em;
        }

        .status {
            font-size: 1.5em;
            margin: 20px;
        }

        .light {
            width: 100px;
            height: 100px;
            margin: 30px auto;
            border-radius: 50%;
            background-color: gray;
            box-shadow: 0 0 20px black;
            transition: 0.5s;
        }

        .on {
            background-color: yellow;
            box-shadow: 0 0 40px yellow;
        }

        button {
            padding: 15px 25px;
            margin: 10px;
            font-size: 1em;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .enter {
            background-color: green;
            color: white;
        }

        .leave {
            background-color: red;
            color: white;
        }
    </style>
</head>
<body>

    <h1>Casamind</h1>
    <p class="status">House Status: Waiting for movement...</p>

    <div id="light" class="light"></div>

    <button class="enter" onclick="enterHouse()">Enter House</button>
    <button class="leave" onclick="leaveHouse()">Leave House</button>

    <script>
        const light = document.getElementById("light");
        const statusText = document.querySelector(".status");

        function enterHouse() {
            light.classList.add("on");
            document.body.style.backgroundColor = "#222";
            statusText.textContent = "Motion detected: Lights ON";
        }

        function leaveHouse() {
            light.classList.remove("on");
            document.body.style.backgroundColor = "#111";
            statusText.textContent = "No movement: Lights OFF";
        }
    </script>

</body>
</html>
